# Server
PORT=3000
NODE_ENV=development

# Database (Supabase / local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/erp_mvp?schema=public"

# Shopee Open Platform — partner.shopeemobile.com
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
SHOPEE_ACCESS_TOKEN=
SHOPEE_BASE_URL=https://partner.shopeemobile.com

# TikTok Shop Partner — partner.tiktokshop.com
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_SHOP_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_BASE_URL=https://open-api.tiktokglobalshop.com

# Sync settings
SYNC_INTERVAL_CRON="*/5 * * * *"

# Public base URL for OAuth callbacks (use ngrok URL during dev)
OAUTH_REDIRECT_BASE=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:3000
