generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(uuid())
  sku       String   @unique
  name      String
  category  String?
  stock     Int      @default(0)
  price     Float    @default(0)
  note      String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([sku])
  @@index([updatedAt])
}

model Order {
  id          String   @id @default(uuid())
  orderNo     String?
  orderedAt   DateTime @default(now())
  platform    String?
  buyer       String?
  sku         String?
  productName String?
  quantity    Int      @default(1)
  price       Float    @default(0)
  total       Float    @default(0)
  status      String   @default("to_ship")
  note        String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([orderedAt])
  @@index([status])
  @@index([sku])
}
