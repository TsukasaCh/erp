generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  passwordHash  String
  fullName      String?
  isSuperAdmin  Boolean  @default(false)
  active        Boolean  @default(true)
  roleId        String?
  role          Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([username])
}

model Role {
  id          String @id @default(uuid())
  name        String @unique
  description String?
  // permissions stored as JSON-encoded string array for cross-DB compat
  permissions String @default("[]")
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Master Kategori Produk
model ProductCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id         String   @id @default(uuid())
  sku        String   @unique
  name       String
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stock      Int      @default(0)
  price      Float    @default(0)
  note       String?
  orders     Order[]
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([sku])
  @@index([updatedAt])
}

model Order {
  id          String   @id @default(uuid())
  orderNo     String?
  orderedAt   DateTime @default(now())
  platform    String?
  buyer       String?
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku         String?
  productName String?
  quantity    Int      @default(1)
  price       Float    @default(0)
  total       Float    @default(0)
  status      String   @default("to_ship")
  note        String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([orderedAt])
  @@index([status])
  @@index([sku])
  @@index([productId])
}

// Master data supplier / toko bahan baku
model Supplier {
  id        String   @id @default(uuid())
  storeName String   @unique
  picName   String?
  phone     String?
  address   String?
  note      String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([storeName])
}

// Master data bahan baku (aluminium, kaca, handle, dst.)
model Material {
  id             String   @id @default(uuid())
  code           String   @unique
  name           String
  category       String?
  unit           String   @default("pcs") // kg, m, batang, pcs, lembar, etc.
  stock          Float    @default(0)
  price          Float    @default(0)     // harga beli per unit
  supplier       String?
  note           String?
  purchaseOrders PurchaseOrder[]
  usages         MaterialUsage[]
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@index([code])
  @@index([category])
}

// Pembelian bahan baku / Purchase Order
model PurchaseOrder {
  id            String   @id @default(uuid())
  poNo          String?
  orderedAt     DateTime @default(now())
  supplier      String?
  materialId    String?
  material      Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
  materialCode  String?
  materialName  String?
  quantity      Float    @default(1)
  unit          String?
  price         Float    @default(0)
  total         Float    @default(0)
  status        String   @default("pending") // pending, received, cancelled
  stockAdjusted Boolean  @default(false) // track if stock was already added
  expectedAt    DateTime?
  note          String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@index([orderedAt])
  @@index([status])
  @@index([materialId])
}

// Pencatatan pengeluaran / penggunaan bahan baku
model MaterialUsage {
  id          String   @id @default(uuid())
  materialId  String
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  quantity    Float    @default(0)
  usageDate   DateTime @default(now())
  purpose     String?  // e.g. "Produksi Jendela Casement", "Proyek A"
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([materialId])
  @@index([usageDate])
}

// Karyawan / Employee
model Employee {
  id          String   @id @default(uuid())
  nik         String   @unique
  fullName    String
  position    String?  // Jabatan
  department  String?  // Departemen
  status      String   @default("aktif") // aktif, cuti, resign, kontrak, tetap
  joinedAt    DateTime @default(now())
  phone       String?
  email       String?
  baseSalary  Float    @default(0)   // gaji pokok bulanan
  allowance   Float    @default(0)   // tunjangan tetap
  overtimeRate Float   @default(0)   // tarif lembur per jam
  note        String?
  attendances Attendance[]
  payrolls    Payroll[]
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([nik])
  @@index([department])
}

// Absensi & Lembur
model Attendance {
  id           String   @id @default(uuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime
  checkIn      String?  // format "HH:mm"
  checkOut     String?  // format "HH:mm"
  status       String   @default("hadir") // hadir, izin, sakit, alpha, cuti
  overtimeHours Float   @default(0)
  note         String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([date])
  @@index([employeeId])
  @@unique([employeeId, date])
}

// Penggajian
model Payroll {
  id           String   @id @default(uuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period       String   // format "YYYY-MM"
  baseSalary   Float    @default(0)
  allowance    Float    @default(0)
  overtimePay  Float    @default(0)
  deduction    Float    @default(0)
  netSalary    Float    @default(0)
  status       String   @default("draft") // draft, paid
  paidAt       DateTime?
  note         String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([period])
  @@index([status])
  @@unique([employeeId, period])
}

// Jadwal produksi
model ProductionSchedule {
  id           String   @id @default(uuid())
  scheduledAt  DateTime
  productSku   String?
  productName  String
  quantity     Int      @default(1)
  status       String   @default("planned") // planned, in_progress, done, cancelled
  assignedTo   String?
  note         String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([scheduledAt])
  @@index([status])
}

// Catatan Aktivitas (Audit Log)
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  username  String
  action    String   // POST, PUT, DELETE
  resource  String   // URL endpoint atau nama modul
  details   String?  // JSON string
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
