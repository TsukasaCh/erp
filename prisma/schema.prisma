generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  passwordHash  String
  fullName      String?
  isSuperAdmin  Boolean  @default(false)
  active        Boolean  @default(true)
  roleId        String?
  role          Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([username])
}

model Role {
  id          String @id @default(uuid())
  name        String @unique
  description String?
  // permissions stored as JSON-encoded string array for cross-DB compat
  permissions String @default("[]")
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id        String   @id @default(uuid())
  sku       String   @unique
  name      String
  category  String?
  stock     Int      @default(0)
  price     Float    @default(0)
  note      String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([sku])
  @@index([updatedAt])
}

model Order {
  id          String   @id @default(uuid())
  orderNo     String?
  orderedAt   DateTime @default(now())
  platform    String?
  buyer       String?
  sku         String?
  productName String?
  quantity    Int      @default(1)
  price       Float    @default(0)
  total       Float    @default(0)
  status      String   @default("to_ship")
  note        String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([orderedAt])
  @@index([status])
  @@index([sku])
}

// Master data bahan baku (aluminium, kaca, handle, dst.)
model Material {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  category  String?
  unit      String   @default("pcs") // kg, m, batang, pcs, lembar, etc.
  stock     Float    @default(0)
  price     Float    @default(0)     // harga beli per unit
  supplier  String?
  note      String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([code])
  @@index([category])
}

// Pembelian bahan baku / Purchase Order
model PurchaseOrder {
  id            String   @id @default(uuid())
  poNo          String?
  orderedAt     DateTime @default(now())
  supplier      String?
  materialCode  String?
  materialName  String?
  quantity      Float    @default(1)
  unit          String?
  price         Float    @default(0)
  total         Float    @default(0)
  status        String   @default("pending") // pending, received, cancelled
  expectedAt    DateTime?
  note          String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@index([orderedAt])
  @@index([status])
}

// Jadwal produksi
model ProductionSchedule {
  id           String   @id @default(uuid())
  scheduledAt  DateTime
  productSku   String?
  productName  String
  quantity     Int      @default(1)
  status       String   @default("planned") // planned, in_progress, done, cancelled
  assignedTo   String?
  note         String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([scheduledAt])
  @@index([status])
}
