# Copy to .env before running docker compose up
# The defaults in docker-compose.yml will be used if left blank.

# ---- Postgres ----
POSTGRES_USER=erp
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=erp

# ---- Shopee Open Platform ----
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
SHOPEE_ACCESS_TOKEN=
SHOPEE_BASE_URL=https://partner.shopeemobile.com

# ---- TikTok Shop ----
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_SHOP_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_BASE_URL=https://open-api.tiktokglobalshop.com

# ---- Sync & OAuth ----
SYNC_INTERVAL_CRON=*/5 * * * *
OAUTH_REDIRECT_BASE=http://localhost:3000

# ---- Frontend (BUILD-TIME — rebuild image after change) ----
NEXT_PUBLIC_API_BASE=http://localhost:3000
