# Copy to .env before running docker compose up
# Defaults in docker-compose.yml will be used if left blank.

# ---- Postgres ----
POSTGRES_USER=erp
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=erp

# ---- Auth ----
# Long random string used to sign JWTs. Generate with: openssl rand -hex 48
JWT_SECRET=change_me_to_a_long_random_string

# ---- Frontend (BUILD-TIME — rebuild web image after change) ----
# Change to your VPS IP / domain for production, e.g. http://168.144.75.208:3000
NEXT_PUBLIC_API_BASE=http://localhost:3000
